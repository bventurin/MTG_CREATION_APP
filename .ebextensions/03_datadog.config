option_settings:
  aws:elasticbeanstalk:application:environment:
    DD_SITE: us5.datadoghq.com
    DD_ENV: production
    DD_SERVICE: AetherFlow-app
    DD_TRACE_ENABLED: "true"
    DD_LOGS_INJECTION: "true"
    DD_RUNTIME_METRICS_ENABLED: "true"

commands:
  01_install_datadog_agent:
    command: |
      DD_API_KEY=$(/opt/elasticbeanstalk/bin/get-config environment -k DD_API_KEY 2>/dev/null || true)
      DD_SITE=$(/opt/elasticbeanstalk/bin/get-config environment -k DD_SITE 2>/dev/null || true)

      if [ -z "$DD_API_KEY" ]; then
        echo "DD_API_KEY is not set. Skipping Datadog Agent installation."
        exit 0
      fi

      if ! rpm -q datadog-agent >/dev/null 2>&1; then
        DD_API_KEY="$DD_API_KEY" DD_SITE="${DD_SITE:-datadoghq.com}" \
        bash -c "$(curl -L https://s3.amazonaws.com/dd-agent/scripts/install_script_agent7.sh)"
      fi

      systemctl enable datadog-agent
      systemctl restart datadog-agent