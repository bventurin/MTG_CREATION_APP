option_settings:
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: DD_AGENT_MAJOR_VERSION
    value: "7"
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: DD_AGENT_MINOR_VERSION
    value: "" # Latest 7.x
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: DD_SITE
    value: "us5.datadoghq.com"
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: DD_ENV
    value: "production"
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: DD_SERVICE
    value: "AetherFlow-app"
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: DD_TRACE_ENABLED
    value: "true"
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: DD_LOGS_INJECTION
    value: "true"
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: DD_RUNTIME_METRICS_ENABLED
    value: "true"

files:
  "/etc/datadog-agent/datadog.yaml":
    mode: "000640"
    owner: root
    group: root
    content: |
      api_key: <API_KEY_PLACEHOLDER>
      site: us5.datadoghq.com
      env: production
      service: AetherFlow-app
      apm_config:
        enabled: true
      logs_enabled: true
      process_config:
        enabled: "true"

  "/datadog_install_script.sh":
    mode: "000700"
    owner: root
    group: root
    source: https://install.datadoghq.com/scripts/install_script_agent7.sh

container_commands:
  04setup_datadog:
    command: |
      DD_API_KEY=$(/opt/elasticbeanstalk/bin/get-config environment -k DD_API_KEY 2>/dev/null || true)
      if [ -z "$DD_API_KEY" ]; then
        echo "DD_API_KEY not set. Skipping Datadog Agent installation."
        exit 0
      fi
      # Inject actual API key into the agent config
      sed -i "s/<API_KEY_PLACEHOLDER>/$DD_API_KEY/" /etc/datadog-agent/datadog.yaml
      # Install/update the agent
      DD_API_KEY=unused /datadog_install_script.sh
      sed -i 's/ install_script/ ebs_install_script/' /etc/datadog-agent/install_info
      # Fix permissions after install (dd-agent user now exists)
      chown dd-agent:dd-agent /etc/datadog-agent/datadog.yaml
      systemctl enable datadog-agent
      systemctl restart datadog-agent
